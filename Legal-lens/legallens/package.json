{
  "name": "legallens",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-router": "~3.5.0",
    "zustand": "^4.5.2",
    "@supabase/supabase-js": "^2.43.2",
    "expo-av": "~14.0.5",
    "expo-location": "~17.0.1",
    "expo-camera": "~15.0.10",
    "expo-speech": "~12.0.2",
    "expo-sqlite": "~14.0.3",
    "@expo/vector-icons": "^14.0.0",
    "react-native-safe-area-context": "4.10.1",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "axios": "^1.7.2",
    "@tanstack/react-query": "^5.40.0",
    "expo-file-system": "~17.0.1",
    "expo-print": "~13.0.1",
    "expo-sharing": "~12.0.1",
    "react": "18.2.0",
    "react-native": "0.74.1"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  },
  "private": true,
  "expo": {
    "name": "LegalLens",
    "slug": "legallens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F7F4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.legallens.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F7F4"
      },
      "package": "com.legallens.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
