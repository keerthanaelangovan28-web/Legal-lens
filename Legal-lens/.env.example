# Database
DATABASE_URL=postgresql://user:password@localhost:5432/legallens

# Redis
REDIS_URL=redis://localhost:6379

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MOCK=true

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Whisper
WHISPER_MODEL_SIZE=tiny
MAX_AUDIO_DURATION_SECONDS=30

# CORS
CORS_ORIGINS=["*"]

# Logging
LOG_LEVEL=INFO
